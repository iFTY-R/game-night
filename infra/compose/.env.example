# Copy this file to infra/compose/.env and replace every change-me value.
# Passwords used inside PostgreSQL and Redis URLs should contain URI-safe characters.

GAME_NIGHT_IMAGE=ghcr.io/ifty-r/game-night:latest
# Must match the non-root UID/GID baked into the application image.
GAME_NIGHT_RUNTIME_UID=10001
GAME_NIGHT_RUNTIME_GID=10001
GAME_NIGHT_SECRETS_DIR=./.tmp/game-night-dev-runtime/secrets
GAME_NIGHT_API_SECRETS_DIR=./.tmp/game-night-dev-runtime/secrets
GAME_NIGHT_WORKER_SECRETS_DIR=./.tmp/game-night-dev-runtime/secrets
GAME_NIGHT_HTTP_BIND_ADDRESS=127.0.0.1
GAME_NIGHT_HTTP_PUBLISHED_PORT=8080
# Must exceed the longest app or launcher graceful-shutdown timeout.
GAME_NIGHT_STOP_GRACE_PERIOD=65s
GAME_NIGHT_NETWORK_NAME=game-night
GAME_NIGHT_NETWORK_SUBNET=172.30.0.0/16
# Optional multi-service mode overrides; keep modes on separate networks when switching locally.
GAME_NIGHT_MULTI_NETWORK_NAME=game-night-multi

GAME_NIGHT_ENVIRONMENT=development
GAME_NIGHT_DATABASE_SCHEMA=game_night
GAME_NIGHT_USER_ORIGINS=http://localhost:8080
GAME_NIGHT_ADMIN_ORIGINS=http://admin.localhost:8080
GAME_NIGHT_SINGLE_TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128
GAME_NIGHT_SINGLE_EDGE_TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128
GAME_NIGHT_TRUSTED_PROXY_CIDRS=172.30.0.0/16,127.0.0.1/32,::1/128
GAME_NIGHT_EDGE_TRUSTED_PROXY_CIDRS=172.30.0.0/16,127.0.0.1/32,::1/128
GAME_NIGHT_COOKIE_SECURE=false
GAME_NIGHT_REDIS_KEY_PREFIX=game-night:compose:
GAME_NIGHT_REDIS_TIMEOUT=1s
GAME_NIGHT_REALTIME_INTERNAL_TOKEN=change-me-realtime-token-at-least-32-characters

GAME_NIGHT_POSTGRES_DB=game_night
GAME_NIGHT_POSTGRES_ADMIN_USER=game_night_admin
GAME_NIGHT_POSTGRES_ADMIN_PASSWORD=change-me-postgres-admin-password
GAME_NIGHT_DATABASE_OWNER_ROLE=game_night_owner
GAME_NIGHT_DATABASE_AUDIT_WRITER_ROLE=game_night_audit_writer
GAME_NIGHT_DATABASE_MIGRATION_ROLE=game_night_migration
GAME_NIGHT_DATABASE_RUNTIME_ROLE=game_night_runtime
GAME_NIGHT_DATABASE_WORKER_ROLE=game_night_worker
GAME_NIGHT_POSTGRES_MIGRATION_LOGIN=game_night_migration_login
GAME_NIGHT_POSTGRES_MIGRATION_PASSWORD=change-me-postgres-migration-password
GAME_NIGHT_POSTGRES_RUNTIME_LOGIN=game_night_runtime_login
GAME_NIGHT_POSTGRES_RUNTIME_PASSWORD=change-me-postgres-runtime-password
GAME_NIGHT_POSTGRES_WORKER_LOGIN=game_night_worker_login
GAME_NIGHT_POSTGRES_WORKER_PASSWORD=change-me-postgres-worker-password
GAME_NIGHT_API_DATABASE_URL=postgresql://game_night_runtime_login:change-me-postgres-runtime-password@postgres.example.internal:5432/game_night?sslmode=require
GAME_NIGHT_REALTIME_DATABASE_URL=postgresql://game_night_runtime_login:change-me-postgres-runtime-password@postgres.example.internal:5432/game_night?sslmode=require
GAME_NIGHT_WORKER_DATABASE_URL=postgresql://game_night_worker_login:change-me-postgres-worker-password@postgres.example.internal:5432/game_night?sslmode=require
GAME_NIGHT_MIGRATION_DATABASE_URL=postgresql://game_night_migration_login:change-me-postgres-migration-password@postgres.example.internal:5432/game_night?sslmode=require

GAME_NIGHT_REDIS_PASSWORD=change-me-redis-password
GAME_NIGHT_REDIS_URL=rediss://:change-me-redis-password@redis.example.internal:6379/0

GAME_NIGHT_MINIO_ROOT_USER=game_night_root
GAME_NIGHT_MINIO_ROOT_PASSWORD=change-me-minio-root-password
GAME_NIGHT_MINIO_APP_ACCESS_KEY=game_night_audit
GAME_NIGHT_MINIO_APP_SECRET_KEY=change-me-minio-app-secret-key
GAME_NIGHT_CHECKPOINT_S3_REGION=us-east-1
GAME_NIGHT_CHECKPOINT_S3_BUCKET=game-night-audit
GAME_NIGHT_CHECKPOINT_S3_ENDPOINT=https://s3.example.internal
GAME_NIGHT_CHECKPOINT_S3_RETENTION=8760h
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=change-me-s3-access-key
AWS_SECRET_ACCESS_KEY=change-me-s3-secret-key
