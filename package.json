{
  "name": "@game-night/root",
  "private": true,
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.13.1"
  },
  "scripts": {
    "build": "turbo run build",
    "check": "pnpm run check:boundaries && turbo run check",
    "check:boundaries": "go run ./tooling/cmd/boundarycheck",
    "check:generated": "node tooling/scripts/check-generated.mjs",
    "generate": "pnpm run generate:game-registry && pnpm run generate:contracts && pnpm run generate:sql",
    "generate:game-registry": "node tooling/scripts/generate-game-registry.mjs",
    "generate:contracts": "node tooling/scripts/generate-contracts.mjs",
    "generate:sql": "go tool sqlc generate -f tooling/sqlc/sqlc.yaml",
    "test": "go test ./... && turbo run test",
    "test:backend:integration": "go test -p 1 -race ./platform/... ./apps/... ./internal/integrationtest/... ./infra/nginx/test/...",
    "test:load": "go run ./apps/realtime/cmd/loadtest",
    "test:web:e2e": "pnpm --filter @game-night/web test:e2e",
    "dev:web": "pnpm --filter @game-night/web dev"
  },
  "devDependencies": {
    "@bufbuild/protobuf": "2.6.2",
    "@bufbuild/protoc-gen-es": "2.6.2",
    "turbo": "2.10.5"
  }
}
